{
  "name": "reshet-components",
  "version": "0.1.2",
  "description": "ReshetComponents React component library extracted from the Daba frontend base components.",
  "type": "module",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/ShpakovNetanel/ReshetComponents"
  },
  "homepage": "https://github.com/ShpakovNetanel/ReshetComponents",
  "bugs": {
    "url": "https://github.com/ShpakovNetanel/ReshetComponents/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.scss",
    "**/*.gif"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build:types": "tsc -p tsconfig.build.json",
    "build:js": "vite build && node ./scripts/inject-entry-css.mjs",
    "build": "npm run clean && npm run build:js && npm run build:types",
    "prepack": "npm run build",
    "pack:check": "npm pack --dry-run",
    "version:canary": "node ./scripts/set-canary-version.mjs"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.554.0",
    "react-day-picker": "^9.13.0",
    "react-hot-toast": "^2.6.0",
    "remeda": "^2.33.4"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "sass": "^1.93.3",
    "typescript": "~5.9.3",
    "vite": "^7.2.2"
  }
}
